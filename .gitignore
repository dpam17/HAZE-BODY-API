# .gitignore
# This file tells Git which files and folders to IGNORE
# — meaning they won't be uploaded to GitHub
# Rule of thumb: ignore anything that is auto-generated,
# environment-specific, or too large for GitHub

# --- Virtual Environment ---
# Your venv folder is huge and machine-specific
# Anyone cloning the repo creates their own venv anyway
venv/

# --- Python Cache Files ---
# These are auto-generated by Python when it runs your code
# They're not needed by anyone cloning the repo
__pycache__/
*.pyc
*.pyo

# --- MediaPipe Model File ---
# The .task model file is large and gets downloaded automatically
# by engine.py on first run — no need to upload it to GitHub
app/models/

# --- Environment Variables ---
# If you ever store API keys or secrets in a .env file
# NEVER upload these to GitHub
.env

# --- VS Code Settings ---
# Your personal VS Code configuration
# Not relevant to anyone else running the project
.vscode/

# --- pytest Cache ---
# Auto-generated when you run pytest
.pytest_cache/

# --- OS Generated Files ---
# Windows sometimes creates these automatically
Thumbs.db
desktop.ini